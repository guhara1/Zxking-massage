---
/**
 * 경기도 행정구(gu) 내 행정동 페이지 — 일반구 보유 7개 시 전용
 * /gyeonggi/[district]/[gu]/[dong]/  (예: /gyeonggi/suwon/jang-an-gu/pajang-dong/)
 *
 * 계층: 경기도 → 시 → 행정구(gu) → 행정동
 * 도어웨이 페이지 방지: 동마다 고유 메타·FAQ·본문
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import Checklist from '../../../../components/Checklist.astro';
import PriceTable from '../../../../components/PriceTable.astro';
import PhoneCTA from '../../../../components/PhoneCTA.astro';
import {
  getDistricts,
  getGuDistricts,
  getDongListByGu,
  stationLabel,
  postposition,
  PROVINCE_LABEL,
} from '../../../../lib/data';
import { webPageSchema, breadcrumbSchema, faqPageSchema } from '../../../../lib/schema';

export const getStaticPaths = (() => {
  const paths = [];
  const cities = getDistricts('gyeonggi');
  for (const city of cities) {
    const gus = getGuDistricts(city.slug);
    for (const gu of gus) {
      const dongs = getDongListByGu(city.slug, gu.slug);
      for (const dong of dongs) {
        paths.push({
          params: { district: city.slug, gu: gu.slug, dong: dong.slug },
          props: { city, gu, dong },
        });
      }
    }
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props {
  city: ReturnType<typeof getDistricts>[number];
  gu: { slug: string; name: string };
  dong: { name: string; slug: string };
}

const { city, gu, dong } = Astro.props;
const cityName = city.city ?? city.name;
const guName = gu.name;
const dongName = dong.name;
const dongSubject = postposition(dongName, '은는');

const path = `/gyeonggi/${city.slug}/${gu.slug}/${dong.slug}/`;

const title = `경기 ${cityName} ${guName} ${dongName} 출장마사지｜방문 가능 지역 · 예약 전 확인사항`;
const description = `경기 ${cityName} ${guName} ${dongName} 출장마사지 방문 가능 지역 안내. ${dongName} 주거환경, 출입 특성, 인근 역세권과 예약 전 확인사항을 확인하세요. 전화예약 0508-202-4719.`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
  { name: cityName, url: `/gyeonggi/${city.slug}/` },
  { name: guName, url: `/gyeonggi/${city.slug}/${gu.slug}/` },
  { name: dongName, url: path },
];

const faqs = [
  {
    question: `${cityName} ${guName} ${dongName}에서 출장마사지 예약이 가능한가요?`,
    answer: `네, ${dongSubject} ${guName} 관할로 방문 예약이 가능한 지역입니다. 다만 아파트·오피스텔·호텔 등 건물에 따라 공동현관 출입 방식이 다르므로 예약 시 정확한 주소와 출입 방식을 미리 안내해 주세요.`,
  },
  {
    question: `${dongName} 출장 추가 이동비가 있나요?`,
    answer: `경기 ${cityName} ${guName} ${dongName}의 기본 출장 이동비는 4만원입니다. 외곽 지역, 심야 시간대의 경우 추가 이동비가 발생할 수 있으니 예약 시 확인해 주세요.`,
  },
  {
    question: `${dongName} 호텔·오피스텔에서도 이용 가능한가요?`,
    answer: `${dongName} 내 호텔·오피스텔 이용은 건물 출입 정책에 따라 다릅니다. 외부인 출입을 제한하는 숙소·건물이 있으므로, 예약 시 숙소명 또는 건물명을 알려주시면 출입 가능 여부를 확인해 드립니다.`,
  },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(faqs),
];

const siblingDongs = getDongListByGu(city.slug, gu.slug).filter((d) => d.slug !== dong.slug).slice(0, 12);
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 28px 0 24px;">
      <div class="tag tag-gold" style="margin-bottom: 14px;">
        {PROVINCE_LABEL.gyeonggi} · {cityName} · {guName} · 행정동
      </div>
      <h1 style="font-size: 1.85rem; font-weight: 800; line-height: 1.35; margin-bottom: 12px;">
        경기 {cityName} {guName} {dongName} 출장마사지 · 방문 가능 지역 안내
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.02rem;">
        {dongSubject} {guName}({cityName}) 관할 행정동으로 방문 예약이 가능한 지역입니다. 주소 기준으로 찾으시는 분들을 위해 {dongName}의 방문 환경과 예약 전 확인사항을 안내합니다.
      </p>
    </section>

    <hr class="divider" />

    <section class="section-sm" id="info">
      <h2 class="section-title">{dongName} <span class="accent">방문 환경 안내</span></h2>
      <p class="section-subtitle">{dongName}의 주요 주거·상권 환경과 출입 특성을 기준으로 예약 시 참고사항을 안내합니다.</p>
      <div class="card-grid card-grid-2">
        <div class="card card-static">
          <h3 class="card__title">📍 주거·상권 환경</h3>
          <p class="card__desc">
            {dongSubject} 경기 {cityName} {guName}에 위치한 행정동으로, 주거지와 상권 특성을 고려해 예약 시간대를 정하시면 좋습니다.
          </p>
        </div>
        <div class="card card-static">
          <h3 class="card__title">🚪 출입 특성</h3>
          <p class="card__desc">
            {dongName} 내 아파트·오피스텔·호텔은 공동현관 출입 통제가 있는 경우가 많습니다. 예약 시 도로명 주소와 건물명, 출입 방식(비밀번호·관리실·공동 출입구)을 미리 안내해 주세요.
          </p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="section-sm" id="station">
      <h2 class="section-title">{dongName} 인근 <span class="accent">역세권 안내</span></h2>
      <p class="section-subtitle">{dongName} 주변 주요 지하철역 기준 안내입니다.</p>
      {city.nearbyStationsData && city.nearbyStationsData.length > 0 ? (
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {city.nearbyStationsData.map((s) => (
            <span class="tag tag-gold" style="padding: 11px 18px; font-size: 0.92rem;">{stationLabel(s)}</span>
          ))}
        </div>
      ) : (
        <div class="callout callout-info">
          {dongName} 주변 역세권 안내는 예약 시 안내해 드립니다.
        </div>
      )}
    </section>

    <hr class="divider" />

    <section class="section-sm" id="use">
      <h2 class="section-title">{dongName} <span class="accent">이용 장소별 확인사항</span></h2>
      <p class="section-subtitle">자택·호텔·오피스텔·외곽·야간 등 이용 상황별로 확인사항이 다릅니다.</p>
      <div class="card-grid">
        <a href="/use/home/" class="card"><h3 class="card__title">자택 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/hotel/" class="card"><h3 class="card__title">호텔·숙소 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/officetel/" class="card"><h3 class="card__title">오피스텔 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/night/" class="card"><h3 class="card__title">야간 예약</h3><span class="card__link">확인하기 →</span></a>
      </div>
    </section>

    <hr class="divider" />

    <section class="section-sm" id="price">
      <h2 class="section-title">{dongName} <span class="accent">코스별 가격 안내</span></h2>
      <PriceTable />
    </section>

    <hr class="divider" />

    <section class="section-sm" id="checklist">
      <Checklist />
    </section>

    <hr class="divider" />

    <PhoneCTA region={`경기 ${cityName} ${guName} ${dongName}`} />

    <hr class="divider" />

    <section class="section-sm">
      <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-item__question">
              <span>{f.question}</span>
              <span class="faq-item__icon">+</span>
            </summary>
            <div class="faq-item__answer">{f.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <hr class="divider" />

    <section class="section-sm" id="nearby">
      <h2 class="section-title" style="font-size: 1.4rem;">{guName} 다른 행정동</h2>
      <p class="section-subtitle">{guName}의 다른 행정동도 확인해 보세요.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {siblingDongs.map((d) => (
          <a href={`/gyeonggi/${city.slug}/${gu.slug}/${d.slug}/`} class="tag tag-link">{d.name}</a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

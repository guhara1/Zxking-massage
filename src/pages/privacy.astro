---
/**
 * 개인정보 처리방침 (/privacy/)
 * 스펙: 모든 주요 페이지에서 연결
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { webPageSchema, breadcrumbSchema } from '../lib/schema';

const path = '/privacy/';
const title = '개인정보 처리방침｜수도권 출장마사지 안내';
const description =
  '수도권 출장마사지 안내 사이트의 개인정보 수집·이용·보관·파기 기준을 안내합니다.';

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '개인정보 처리방침', url: '/privacy/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <section style="padding: 24px 0 32px;">
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        개인정보 처리방침
      </h1>
      <p style="color: var(--color-text-muted); font-size: 0.9rem;">
        최종 수정일: 2026년 6월 27일
      </p>
    </section>

    <section class="section-sm">
      <div class="prose">
        <p>
          본 사이트는 방문형 건강 관리 정보 안내 목적으로 운영되며, 예약 문의 과정에서
          최소한의 개인정보를 수집합니다. 아래 기준에 따라 개인정보를 처리합니다.
        </p>

        <h2>1. 수집하는 개인정보 항목</h2>
        <p>예약 문의 시 아래 정보를 수집할 수 있습니다.</p>
        <ul>
          <li>연락처(전화번호 또는 메신저 ID)</li>
          <li>방문 주소(도로명 주소 및 건물명)</li>
          <li>예약 희망 시간 및 이용 장소 정보</li>
        </ul>

        <h2>2. 수집 및 이용 목적</h2>
        <ul>
          <li>예약 문의 응대 및 방문 가능 여부 확인</li>
          <li>방문 주소 확인 및 매니저 안내</li>
          <li>예약 변경·취소 안내</li>
        </ul>

        <h2>3. 보관 및 이용 기간</h2>
        <p>
          수집된 개인정보는 예약 안내 목적 달성 후 즉시 파기하는 것을 원칙으로 합니다.
          단, 관련 법령에 따라 보존이 필요한 경우 해당 기간 동안 보관할 수 있습니다.
        </p>

        <h2>4. 개인정보 제3자 제공</h2>
        <p>
          원칙적으로 이용자의 동의 없이 개인정보를 제3자에게 제공하지 않습니다.
          방문 서비스 제공을 위해 필요 최소한의 정보(방문 주소, 연락처)를 담당 매니저에게
          전달할 수 있습니다.
        </p>

        <h2>5. 이용자의 권리</h2>
        <p>
          이용자는 언제든지 본인의 개인정보 열람·수정·삭제를 요청할 수 있으며,
          예약 취소 시 수집된 정보의 즉시 파기를 요구할 수 있습니다.
        </p>

        <h2>6. 개인정보 처리 문의</h2>
        <p>
          개인정보 처리와 관련한 문의는 <a href="/contact/">고객센터</a>를 통해 접수해 주시기 바랍니다.
        </p>

        <div class="callout callout-info">
          <div class="callout__title">안내 목적 운영</div>
          본 사이트는 합법적인 방문형 건강 관리 정보 안내 목적으로 운영됩니다.
          수집된 정보는 안내 목적 외에는 사용되지 않습니다.
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

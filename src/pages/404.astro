---
/**
 * 404 페이지 - 존재하지 않는 경로로 접근 시 노출
 * 사용자를 메인/주요 페이지로 안내
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPageSchema } from '../lib/schema';

const path = '/404/';
const title = '페이지를 찾을 수 없습니다｜수도권 출장마사지 안내';
const description = '요청하신 페이지를 찾을 수 없습니다. 수도권 출장마사지 메인이나 지역 안내로 이동해 주세요.';

const schemas = [webPageSchema(path, title, description)];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container" style="text-align: center; padding: 100px 20px;">
    <div style="font-size: 5rem; font-weight: 800; color: var(--color-primary); line-height: 1; margin-bottom: 16px;">
      404
    </div>
    <h1 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 14px;">
      페이지를 찾을 수 없습니다
    </h1>
    <p style="color: var(--color-text-soft); max-width: 480px; margin: 0 auto 36px; font-size: 1.05rem;">
      요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.
      아래에서 수도권 출장마사지 지역 안내로 이동해 보세요.
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
      <a href="/" class="btn btn-primary">홈으로 가기</a>
      <a href="/seoul/" class="btn btn-secondary">서울 보기</a>
      <a href="/gyeonggi/" class="btn btn-secondary">경기 보기</a>
      <a href="/incheon/" class="btn btn-secondary">인천 보기</a>
      <a href="/life/" class="btn btn-secondary">생활권 찾기</a>
    </div>
  </div>
</BaseLayout>

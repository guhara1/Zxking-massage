---
/**
 * 브레드크럼 네비게이션 컴포넌트
 * 시각적 브레드크럼 + BreadcrumbList 스키마는 SEO.astro에서 함께 처리
 */
import type { BreadcrumbItem } from '../lib/types';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="브레드크럼">
  {items.map((item, idx) => (
    <>
      {idx > 0 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
      {idx === items.length - 1 ? (
        <span class="breadcrumb__current">{item.name}</span>
      ) : (
        <a href={item.url}>{item.name}</a>
      )}
    </>
  ))}
</nav>
